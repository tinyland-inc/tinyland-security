{
  "name": "@tummycrypt/tinyland-security",
  "version": "0.2.2",
  "description": "IP hashing, encryption, risk scoring, device detection, VPN detection, rate limiting, and timing-safe utilities",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build && pnpm check:package",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "check:package": "publint"
  },
  "keywords": [
    "security",
    "ip-hashing",
    "rate-limiting",
    "device-detection",
    "vpn-detection",
    "risk-scoring",
    "fingerprint",
    "timing-safe"
  ],
  "author": "Tinyland.dev",
  "license": "Zlib AND LicenseRef-Tinyland-Proprietary",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyland-inc/tinyland-security.git"
  },
  "dependencies": {},
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@types/node": "^20.0.0",
    "fast-check": "^4.3.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0",
    "publint": "^0.3.18",
    "@tummycrypt/tinyland-auth": "^0.2.2"
  },
  "peerDependencies": {
    "@tummycrypt/tinyland-auth": "^0.2.2",
    "@maxmind/geoip2-node": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@tummycrypt/tinyland-auth": {
      "optional": true
    },
    "@maxmind/geoip2-node": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "pnpm@10.13.1",
  "homepage": "https://github.com/tinyland-inc/tinyland-security",
  "bugs": {
    "url": "https://github.com/tinyland-inc/tinyland-security/issues"
  }
}