{
  "name": "@tinyland-inc/tinyland-security",
  "version": "0.1.0",
  "description": "IP hashing, encryption, risk scoring, device detection, VPN detection, rate limiting, and timing-safe utilities",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "security",
    "ip-hashing",
    "rate-limiting",
    "device-detection",
    "vpn-detection",
    "risk-scoring",
    "fingerprint",
    "timing-safe"
  ],
  "author": "Tinyland.dev",
  "license": "Zlib AND LicenseRef-Tinyland-Proprietary",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/tinyland/tinyland.dev",
    "directory": "packages/tinyland-security"
  },
  "dependencies": {},
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@types/node": "^20.0.0",
    "fast-check": "^4.3.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@tinyland-inc/tinyland-auth": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@tinyland-inc/tinyland-auth": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
